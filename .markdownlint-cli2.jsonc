// markdownlint-cli2 configuration specifying globs (so scripts need no args)
// Reference: https://github.com/DavidAnson/markdownlint-cli2#configuration
{
  "globs": [
    "*.md",
    "docs/**/*.md",
    "src/**/*.md",
    "scripts/**/*.md",
    ".github/*.md",
    ".github/ISSUE_TEMPLATE/**/*.md"
  ],
  "fix": false
}

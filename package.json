{
  "name": "civitas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack && bun run headers:apply",
    "build:static": "STATIC_EXPORT=1 next build --webpack && bun run headers:apply",
    "start": "next start",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format": "biome format . --write",
    "format:check": "biome format . --check",
    "type-check": "tsc --noEmit",
    "pre-commit": "lefthook run pre-commit",
    "prepare": "lefthook install",
    "headers:apply": "cp static-headers/_headers out/_headers || echo 'skip headers copy (out/ missing)'",
    "snapshot:parliament": "bun run scripts/generateParliamentSnapshot.ts --date 2021-01-01T00-00-00Z",
    "snapshot:partyMeta": "bun run scripts/generatePartyMeta.ts --snapshot public/data/parliament-2021-01-01T00-00-00Z.json",
    "snapshot:range:terms": "bun run scripts/generateParliamentSnapshotsRange.ts --mode terms --throttle 300",
    "snapshot:official": "bun run scripts/generateOfficialTimeline.ts --since 2005-01-01 --granularity events",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest",
    "test:unit:run": "vitest run"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "csv-loader": "^3.0.5",
    "d3": "^7.8.5",
    "next": "^16.2.2",
    "p-limit": "^5.0.0",
    "react": "^18",
    "react-dom": "^18",
    "wikibase-sdk": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.0.1",
    "daisyui": "^4.7.2",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "markdownlint-cli2": "^0.22.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^4.0.0"
  }
}
